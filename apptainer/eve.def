Bootstrap: docker
From: python:3.14.3

%labels
    Author Dylan Woods
    Application EvE
    Version 0.3.1

%files
    ../src /opt/eve/src
    ../README.md /opt/eve
    ../LICENSE /opt/eve
    ../requirements.txt /opt/eve
    ../eve.py /opt/eve

%environment
    export PATH=/opt/eve:$PATH
    export PYTHONUNBUFFERED=1

%post
    pip install --no-cache-dir -r /opt/eve/requirements.txt

%runscript
    cd /opt/eve
    exec python eve.py "$@"
